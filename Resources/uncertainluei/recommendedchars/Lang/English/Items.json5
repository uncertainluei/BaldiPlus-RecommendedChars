{
	// Birthday Cake
	"Itm_RecChars_BaldiCake": "Baldi's Birthday Cake",
	"Desc_RecChars_BaldiCake": "Baldi's Birthday Cake\nA small slice of (assumedly) Baldi's GIANT birthday cake!\nJust remember: it's quite sugary, so eat it at your own risk!",
	"Sfx_RecChars_EatingShort": "[Eating like an animal]",

	// BSODA Mini and Diet BSODA Mini
	"Itm_RecChars_SmallBsoda": "BSODA Mini",
	"Itm_RecChars_SmallDietBsoda": "Diet BSODA Mini",

	"Desc_RecChars_SmallBsoda": "BSODA Mini\nThe original fizzed-up BSODA in a sip-sized can!\nLeverage the slightly lower speed with the original fizz!",
	"Desc_RecChars_SmallDietBsoda": "Diet BSODA Mini\nFor budgeting (and balancing) reasons, we have made Diet BSODA available\nin sip-sized cans! Now the healthier alternative is in smaller capacity for short bursts!",

	// Door Key
	"Itm_RecChars_DoorKey": "Door Key",
	"Desc_RecChars_DoorKey": "Door Key\nThe end-all-be-all solution to unlocking all (non-swinging) doors!\nIt is also quite sturdy for its use case...",

	// Lunch Box
	// Someone lost their lunch box, and i snatched it. I dont know what's inside it so i just slapped a random price hoping i dont sell something good for a low price
	// - john johnny jonathan
	"Itm_RecChars_LunchBox": "Lunch Box",
	"Desc_RecChars_LunchBox": "Lunch Box\nSomeone lost their lunch box, but finder's keepers!\nDon't ask what's inside it, I really don't know.",

	// Nerf Gun
	"Itm_RecChars_NerfGun": "Nerf Gun",
	"Desc_RecChars_NerfGun": "Nerf Gun\nAn amazing toy with zero safety concerns whatsoever!\nFor legal reasons, you can only squirt water at rainbows with this.",

	// Pie
	"Itm_RecChars_Pie": "Pie",
	"Desc_RecChars_Pie": "Pie\nOne of Dave's countless home-baked pies! While you could eat it,\nit's more fun to throw these towards unsuspecting victims!",
	"Sfx_RecChars_PieSplat": "[SPLAT!]",

	// PSODA
    "Itm_RecChars_Psoda": "PSODA",
    "Itm_RecChars_SmallPsoda": "PSODA Mini",
	"Sfx_RecChars_Boing": "[Boing!]",

    "Desc_RecChars_Psoda": "PSODA\nA special limited-edition flavored BSODA!\nIts unique pink fizz will propel <b>anyone</b> like a golf ball!",
    "Desc_RecChars_SmallPsoda": "PSODA Mini\nPSODA is already limited in its normal size, so I\nsay this is a rare find! Don't take my word for it, though.",
