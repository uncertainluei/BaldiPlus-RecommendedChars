	"Opt_RecChars_Misc_LegacyTextures": "Legacy Textures",
	"Tip_RecChars_ApplyMisc":"Apply miscellaneous toggles.\nUnapplied settings will not be saved.",
	"Tip_RecChars_Misc_PartyMode": "Sets how Party Mode will trigger.\nIf date-based, then it will turn on only in May 1st-22nd.\n<color=red>Requires game restart for changes to apply!</color>",
	"Tip_RecChars_Misc_GuaranteeSpawn": "Makes all the mod's NPCs force-spawn in their earliest floor.\n<color=red>Requires game restart for changes to apply!</color>",
	"Tip_RecChars_Misc_LegacyTextures": "Reverts texture changes made throughout the mod's development\nto reflect those sent by the requesters.",
		
	"Opt_RecChars_RestartRequired": "<color=red>A game restart is required for these options to apply!\nKnowing this, do you wish to close the game?</color>",
	
